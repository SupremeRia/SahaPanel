# Supabase proje URL'i
# Supabase panelinde: Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Supabase public anon (anonim) anahtari
# Supabase panelinde: Project Settings -> API -> Project API keys -> anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase servis rolu (secret) anahtari — SUNUCU TARAFI, GIZLI.
# Supabase panelinde: Project Settings -> API keys -> secret key (sb_secret_...)
# Kayit onayinda personelin e-postasini otomatik dogrulamak icin kullanilir;
# bu sayede e-posta dogrulamasi acik olsa bile onaylanan personel giris yapabilir.
# NEXT_PUBLIC_ ONEKI YOKTUR: asla istemciye gonderilmez. Uretimde Vercel ortam
# degiskeni olarak tanimlayin; koda / git'e asla yazmayin.
SUPABASE_SECRET_KEY=your-supabase-secret-key
